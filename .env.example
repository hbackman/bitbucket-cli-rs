# Copy to `.env` and fill in. `.env` is gitignored.
#
# These are read by `build.rs` at compile time and embedded into the binary,
# so re-run `cargo build` after editing. They are also picked up at runtime
# by `bb auth login` (which lets you test without rebuilding the binary).

BB_OAUTH_CLIENT_ID=
BB_OAUTH_CLIENT_SECRET=
